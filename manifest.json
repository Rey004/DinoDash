{
  "manifest_version": 3,
  "name": "DinoDash - Interactive New Tab & Enhanced Dino Game",
  "version": "1.0",
  "description": "Transform your new tab with productivity widgets, smart history, favorite links, themes, and an enhanced Dino game.",
  "icons": {
    "16": "assets/brand/icon-16.png",
    "32": "assets/brand/icon-32.png",
    "48": "assets/brand/icon-48.png",
    "128": "assets/brand/icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "src/index.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "optional_permissions": [
    "history"
  ],
  "action": {
    "default_icon": {
      "16": "assets/brand/icon-16.png",
      "24": "assets/brand/icon-24.png",
      "32": "assets/brand/icon-32.png",
      "48": "assets/brand/icon-48.png"
    },
    "default_popup": "popup.html",
    "default_title": "DinoDash"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
